{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-stats.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__zephyr-scale__|mcp__mssql|mcp__playwright__|mcp__claude_ai_Atlassian",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/memory-inject.ps1\""
          }
        ]
      },
      {
        "matcher": "mcp__mssql",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-sql.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__zephyr-scale__",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PLUGIN_ROOT}/hooks/log-skill-run.ps1\""
          }
        ]
      }
    ]
  }
}
